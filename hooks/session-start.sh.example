#!/bin/bash
# Session Start Hook — Context Essentials
# Injects minimal context at every session start.
# Output is printed to stdout and delivered to Claude as additional context.

# Customize the values below for your setup:
USER_NAME="Your Name"
USER_ROLE="Your Role"
USER_INDUSTRY="Your Industry"
SKILLS="capture, distill, express, analyze, signal-check, handoff"

echo "Session context: ${USER_NAME} is a ${USER_ROLE} in ${USER_INDUSTRY}. Available skills: ${SKILLS}. Project states: ~/.claude/orchestrator/projects/. Memory: ~/.claude/memory/."
